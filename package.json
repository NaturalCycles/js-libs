{
  "name": "js-libs",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "upd": "pnpm -r up --no-save",
    "out": "pnpm -r outdated",
    "ci:setup": "pnpm install && pnpm build",
    "build": "pnpm --filter '@naturalcycles/*' --parallel exec tsc -P tsconfig.prod.json --noCheck --incremental false",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "check": "pnpm build && pnpm dev-lib:linter-rules-dump && pnpm lint && pnpm typecheck && pnpm test",
    "check:ci": "pnpm build && pnpm lint:ci && pnpm typecheck && pnpm test",
    "quick-check": "pnpm build && pnpm lint && pnpm test",
    "qc": "pnpm quick-check",
    "typecheck": "pnpm --filter '@naturalcycles/*' run typecheck",
    "lint": "oxlint --fix --fix-suggestions && oxfmt",
    "lint:ci": "oxlint && oxfmt --check",
    "test": "vitest run",
    "test:each": "pnpm --filter '@naturalcycles/*' run test",
    "bt": "pnpm build && pnpm --filter '@naturalcycles/*' run bt",
    "dev-lib:linter-rules-dump": "pnpm --dir packages/dev-lib exec tsx scripts/oxlintPrintConfig.script.ts",
    "dev-lib:linter-rules-dump-backup": "pnpm --dir packages/dev-lib exec tsx scripts/eslintPrintConfig.script.ts && pnpm --dir packages/dev-lib exec tsx scripts/oxlintPrintConfig.script.ts",
    "dev-lib:build": "pnpm --filter @naturalcycles/dev-lib run build",
    "dev-lib:lint": "pnpm --filter @naturalcycles/dev-lib run lint",
    "dev-lib:test": "pnpm --filter @naturalcycles/dev-lib run test",
    "dev-lib:check": "pnpm --filter @naturalcycles/dev-lib run check",
    "dev-lib:typecheck": "pnpm --filter @naturalcycles/dev-lib run typecheck",
    "dev-lib:bt": "pnpm --filter @naturalcycles/dev-lib run bt",
    "js-lib:check": "pnpm --filter @naturalcycles/js-lib run check",
    "js-lib:lint": "pnpm --filter @naturalcycles/js-lib run lint",
    "js-lib:build": "pnpm --filter @naturalcycles/js-lib run build",
    "js-lib:bt": "pnpm --filter @naturalcycles/js-lib run bt",
    "js-lib:test": "pnpm --filter @naturalcycles/js-lib run test",
    "nodejs-lib:check": "pnpm --filter @naturalcycles/nodejs-lib run check",
    "nodejs-lib:test": "pnpm --filter @naturalcycles/nodejs-lib run test",
    "nodejs-lib:bt": "pnpm --filter @naturalcycles/nodejs-lib run bt",
    "nodejs-lib:build": "pnpm --filter @naturalcycles/nodejs-lib run build",
    "backend-lib:check": "pnpm --filter @naturalcycles/backend-lib run check",
    "backend-lib:bt": "pnpm --filter @naturalcycles/backend-lib run bt",
    "backend-lib:test": "pnpm --filter @naturalcycles/backend-lib run test",
    "db-lib:build": "pnpm --filter @naturalcycles/db-lib run build",
    "db-lib:check": "pnpm --filter @naturalcycles/db-lib run check",
    "db-lib:bt": "pnpm --filter @naturalcycles/db-lib run bt",
    "db-lib:test": "pnpm --filter @naturalcycles/db-lib run test",
    "datastore-lib:check": "pnpm --filter @naturalcycles/datastore-lib run check",
    "datastore-lib:bt": "pnpm --filter @naturalcycles/datastore-lib run bt",
    "datastore-lib:lint": "pnpm --filter @naturalcycles/datastore-lib run lint",
    "datastore-lib:test": "pnpm --filter @naturalcycles/datastore-lib run test",
    "firestore-lib:check": "pnpm --filter @naturalcycles/firestore-lib run check",
    "firestore-lib:bt": "pnpm --filter @naturalcycles/firestore-lib run bt",
    "firestore-lib:lint": "pnpm --filter @naturalcycles/firestore-lib run lint",
    "abba:check": "pnpm --filter @naturalcycles/abba run check",
    "abba:bt": "pnpm --filter @naturalcycles/abba run bt",
    "mongo-lib:check": "pnpm --filter @naturalcycles/mongo-lib run check",
    "mongo-lib:bt": "pnpm --filter @naturalcycles/mongo-lib run bt",
    "redis-lib:check": "pnpm --filter @naturalcycles/redis-lib run check",
    "redis-lib:bt": "pnpm --filter @naturalcycles/redis-lib run bt",
    "sqlite-lib:check": "pnpm --filter @naturalcycles/sqlite-lib run check",
    "sqlite-lib:bt": "pnpm --filter @naturalcycles/sqlite-lib run bt",
    "mysql-lib:check": "pnpm --filter @naturalcycles/mysql-lib run check",
    "mysql-lib:bt": "pnpm --filter @naturalcycles/mysql-lib run bt",
    "airtable-lib:check": "pnpm --filter @naturalcycles/airtable-lib run check",
    "airtable-lib:bt": "pnpm --filter @naturalcycles/airtable-lib run bt",
    "bench-lib:check": "pnpm --filter @naturalcycles/bench-lib run check",
    "bench-lib:bt": "pnpm --filter @naturalcycles/bench-lib run bt",
    "cloud-storage-lib:check": "pnpm --filter @naturalcycles/cloud-storage-lib run check",
    "cloud-storage-lib:bt": "pnpm --filter @naturalcycles/cloud-storage-lib run bt",
    "scrubber-lib:check": "pnpm --filter @naturalcycles/scrubber-lib run check",
    "scrubber-lib:bt": "pnpm --filter @naturalcycles/scrubber-lib run bt",
    "release": "dev-lib release",
    "release:dry": "dev-lib release --dry-run",
    "release:dev-lib": "dev-lib release --filter dev-lib",
    "release:dev-lib:dry": "dev-lib release --filter dev-lib --dry-run",
    "docs:dev": "pnpx vitepress@^1 dev docs --open",
    "docs:build": "pnpx vitepress@^1 build docs",
    "docs:preview": "pnpx vitepress@^1 preview docs"
  },
  "devDependencies": {
    "@naturalcycles/bench-lib": "workspace:*",
    "@naturalcycles/dev-lib": "workspace:*",
    "@naturalcycles/nodejs-lib": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@vitest/coverage-v8": "^4",
    "husky": "^9",
    "oxfmt": "^0",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "^4",
    "vite": "^8",
    "vitest": "^4"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@11.15.1"
}
